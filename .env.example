# IGDB API Credentials (Twitch Developer Console)
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret

# Database
# Use DB_HOST=db when running via Docker Compose (internal network).
# Use DB_HOST=localhost when running the app directly on your machine.
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=modo_locadora
DATABASE_URL=postgres://your_user:your_password@localhost:5432/modo_locadora?sslmode=disable

# Security
COOKIE_SECRET=gere_uma_chave_secreta_aleatoria_aqui
ADMIN_EMAIL=admin@locadora.com
